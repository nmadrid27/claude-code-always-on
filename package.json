{
  "name": "claude-code-always-on",
  "version": "0.1.0",
  "description": "24/7 AI assistant using Claude Code + MCP with Telegram interface",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "type-check": "tsc --noEmit",
    "service:install": "bash scripts/install-service.sh install",
    "service:uninstall": "bash scripts/install-service.sh uninstall",
    "service:start": "bash scripts/install-service.sh start",
    "service:stop": "bash scripts/install-service.sh stop",
    "service:restart": "bash scripts/install-service.sh restart",
    "service:status": "bash scripts/install-service.sh status",
    "service:logs": "bash scripts/install-service.sh logs"
  },
  "keywords": [
    "claude",
    "telegram-bot",
    "ai-assistant",
    "voice"
  ],
  "author": "Nathan Madrid",
  "license": "MIT",
  "module": "src/index.ts",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "dotenv": "^17.2.4",
    "grammy": "^1.40.0"
  }
}
