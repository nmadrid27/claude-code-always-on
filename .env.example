# ==============================================================================
# Claude Code Always-On - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# -----------------------------------------------------------------------------
# REQUIRED: Telegram Configuration
# -----------------------------------------------------------------------------

# Get your bot token from @BotFather on Telegram
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the token provided
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (comma-separated for multiple users)
# 1. Message your bot after creating it
# 2. Visit: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 3. Find your "from":{"id":123456789} in the response
# SECURITY: Only users in this list can use the bot
ALLOWED_USER_IDS=your_user_id_here

# -----------------------------------------------------------------------------
# REQUIRED: Claude Code Configuration
# -----------------------------------------------------------------------------

# Timeout for Claude Code execution (milliseconds)
# Min: 1000 (1 second), Max: 600000 (10 minutes)
CLAUDE_TIMEOUT=300000

# Default permission level: read_only, safe, standard, full
# - read_only: Can only read files
# - safe: Can execute safe commands (no writes, no network)
# - standard: Can execute most commands with confirmation
# - full: Can execute any command (use with caution!)
DEFAULT_PERMISSION_LEVEL=standard

# NEVER auto-execute commands - always require confirmation
CLAUDE_AUTO_APPROVE=false

# -----------------------------------------------------------------------------
# OPTIONAL: Supabase (for semantic memory)
# -----------------------------------------------------------------------------

# Get these from your Supabase project settings
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Voyage AI (for semantic memory embeddings)
# Get your key at https://dash.voyageai.com
# -----------------------------------------------------------------------------

VOYAGE_API_KEY=your_voyage_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Voice Services
# -----------------------------------------------------------------------------

# ElevenLabs for text-to-speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_agent_id_here
ELEVENLABS_SIGNING_SECRET=your_elevenlabs_signing_secret_here

# Twilio for phone calls
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Gemini API for voice transcription
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Bot Persona
# -----------------------------------------------------------------------------

# Your name (used in system prompt — e.g., "Alex", "Jamie")
OWNER_NAME=your_name_here

# Bot display name (your Telegram bot's handle or a friendly name)
BOT_NAME=your_bot_name_here

# Timezone for proactive check-ins (IANA format, e.g., America/New_York, Europe/London)
USER_TIMEZONE=America/Los_Angeles

# -----------------------------------------------------------------------------
# OPTIONAL: Application Configuration
# -----------------------------------------------------------------------------

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Rate limiting: max requests per minute per user
RATE_LIMIT_MAX_REQUESTS=10

# Rate limiting: time window in milliseconds
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL: Feature Flags
# -----------------------------------------------------------------------------

# Enable voice features (requires ElevenLabs and Twilio)
FEATURE_VOICE_ENABLED=false

# Enable semantic memory (requires Supabase and Voyage AI)
FEATURE_MEMORY_ENABLED=false

# Enable proactive check-ins
FEATURE_PROACTIVE_CHECKINS=false

# Interval for proactive check-ins (in minutes)
PROACTIVE_CHECKIN_INTERVAL_MINUTES=30
