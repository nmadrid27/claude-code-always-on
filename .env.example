# ==============================================================================
# Claude Code Always-On - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control. (.env is in .gitignore.)
#
# Tip: chmod 600 .env after editing.

# -----------------------------------------------------------------------------
# REQUIRED: Telegram
# -----------------------------------------------------------------------------

# Get your bot token from @BotFather on Telegram:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the prompts
#   3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of Telegram numeric user IDs allowed to use this bot.
# Get your own user ID by messaging @userinfobot on Telegram.
# SECURITY: Only users in this list can talk to the bot. Do not leave empty.
ALLOWED_USER_IDS=your_user_id_here

# -----------------------------------------------------------------------------
# REQUIRED: Claude / Anthropic
# -----------------------------------------------------------------------------

# Anthropic API key. Used by the Claude Code CLI that the bot spawns.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Timeout for Claude Code execution (milliseconds).
# Min: 1000 (1s). Max: 600000 (10 min). Default: 300000 (5 min).
CLAUDE_TIMEOUT=300000

# Default permission level: read_only | safe | standard | full
DEFAULT_PERMISSION_LEVEL=standard

# Never auto-approve commands; always require confirmation.
CLAUDE_AUTO_APPROVE=false

# -----------------------------------------------------------------------------
# REQUIRED (for memory features): Supabase
# -----------------------------------------------------------------------------
# If you do not need conversation memory, set FEATURE_MEMORY_ENABLED=false
# at the bottom of this file and you can skip these.

# Supabase project URL (Project Settings > API > URL)
SUPABASE_URL=https://your-project.supabase.co

# Service role key (Project Settings > API > service_role).
# KEEP SECRET. This bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anon (public) key (Project Settings > API > anon).
# Only needed if you also use client-side Supabase access.
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# REQUIRED (for memory features): Voyage AI embeddings
# -----------------------------------------------------------------------------
# Get a key at https://dash.voyageai.com (free tier available).

VOYAGE_API_KEY=your_voyage_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Bot persona
# -----------------------------------------------------------------------------

# Your name (used in the system prompt, e.g. "Alex", "Jamie")
OWNER_NAME=your_name_here

# Bot display name
BOT_NAME=your_bot_name_here

# IANA timezone for proactive check-ins (e.g. America/New_York, Europe/London)
USER_TIMEZONE=America/Los_Angeles

# -----------------------------------------------------------------------------
# OPTIONAL: Webhook mode (for voice features, or to receive Telegram webhooks)
# -----------------------------------------------------------------------------
# Default is polling mode (no public URL required). Switch to webhook only if
# you need ElevenLabs/Twilio integration.

# 'polling' (default; recommended for development) or 'webhook'
BOT_MODE=polling

# Public HTTPS URL where this bot is reachable (only required for webhook mode)
WEBHOOK_URL=https://your-public-url.example.com

# Random shared secret used to validate incoming Telegram webhook requests
WEBHOOK_SECRET=a_random_secret_string

# Local port the webhook server listens on (default 3000)
WEBHOOK_PORT=3000

# Public base URL used when generating Twilio voice webhook URLs
WEBHOOK_BASE_URL=https://your-public-url.example.com

# -----------------------------------------------------------------------------
# OPTIONAL: Voice (ElevenLabs)
# -----------------------------------------------------------------------------
# Required only if FEATURE_VOICE_ENABLED=true below.

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
ELEVENLABS_REGION=us
ELEVENLABS_SIGNING_SECRET=your_elevenlabs_signing_secret_here

# -----------------------------------------------------------------------------
# OPTIONAL: Voice (Twilio)
# -----------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# Maps inbound phone numbers to Telegram user IDs for context lookup.
# Format: +15551234567:123456789,+15559876543:987654321
PHONE_USER_MAP=

# -----------------------------------------------------------------------------
# OPTIONAL: Voice transcription (Gemini)
# -----------------------------------------------------------------------------

GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Logging and rate limiting
# -----------------------------------------------------------------------------

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Max requests per minute per user
RATE_LIMIT_MAX_REQUESTS=10

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# OPTIONAL: Feature flags
# -----------------------------------------------------------------------------

# Enable voice features (requires ElevenLabs and Twilio above)
FEATURE_VOICE_ENABLED=false

# Enable semantic memory (requires Supabase and Voyage AI above)
FEATURE_MEMORY_ENABLED=false

# Enable proactive check-ins (morning briefings, evening summaries)
FEATURE_PROACTIVE_CHECKINS=false

# Interval for proactive check-ins (minutes)
PROACTIVE_CHECKIN_INTERVAL_MINUTES=30
